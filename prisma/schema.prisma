generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User ────────────────────────────────────────────────────────────

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  passwordHash          String
  firstName             String
  lastName              String
  country               String?
  role                  String    @default("USER") // USER | COACH | SUPER_ADMIN
  plan                  String    @default("FREE")
  planStatus            String    @default("PENDING")
  unitPreference        String    @default("METRIC")
  isActive              Boolean   @default(true)
  paymentScreenshot     String?
  paymentAccountName    String?
  paymentTransactionRef String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  lastLoginAt           DateTime?

  // Multi-tenant fields
  coachId       String?
  isCoachActive Boolean  @default(true)
  inviteCode    String?  @unique

  // Health profile fields
  age              Int?
  gender           String?
  heightCm         Float?
  currentWeightKg  Float?
  bodyFatPercent    Float?
  fitnessGoal      String?
  activityLevel    String?
  dietaryPrefs     String?
  healthConditions String?
  targetWeightKg   Float?

  // Self-referencing coach ↔ client relation
  coach   User?  @relation("CoachClients", fields: [coachId], references: [id])
  clients User[] @relation("CoachClients")

  // User tracking relations
  weightLogs           WeightLog[]
  progressPhotos       ProgressPhoto[]
  mealLogs             MealLog[]
  macroTarget          UserMacroTarget?
  assets               Asset[]
  favourites           Favourite[]
  sentMessages         Message[]          @relation("SentMessages")
  receivedMessages     Message[]          @relation("ReceivedMessages")
  posts                Post[]
  postLikes            PostLike[]
  postComments         PostComment[]
  stepLogs             StepLog[]
  bodyMeasurements     BodyMeasurement[]
  notifications        Notification[]
  reminders            UserReminder[]
  clientPlans          ClientPlan[]
  dailyProgress        DailyProgress[]
  weeklyTargets        WeeklyTarget[]
  activePlanId         Int?

  // Coach-owned content relations (reverse side)
  coachRecipes          Recipe[]            @relation("CoachRecipes")
  coachRecipeCategories RecipeCategory[]    @relation("CoachRecipeCategories")
  coachDietaryTags      DietaryTag[]        @relation("CoachDietaryTags")
  coachWorkouts         Workout[]           @relation("CoachWorkouts")
  coachWorkoutCats      WorkoutCategory[]   @relation("CoachWorkoutCats")
  coachWorkoutSubs      WorkoutSubcategory[] @relation("CoachWorkoutSubs")
  coachFoodItems        FoodItem[]          @relation("CoachFoodItems")
  coachPlanTemplates    PlanTemplate[]      @relation("CoachPlanTemplates")
  coachPosts            Post[]              @relation("CoachPosts")
  coachAssets           Asset[]             @relation("CoachAssets")
  coachSiteContent      SiteContent[]       @relation("CoachSiteContent")
  coachPaymentSettings  PaymentSettings?    @relation("CoachPaymentSettings")
  coachBilling          CoachBilling?       @relation("CoachBilling")

  @@index([coachId])
}

// ─── Coach Billing ──────────────────────────────────────────────────

model CoachBilling {
  id               Int       @id @default(autoincrement())
  coachId          String    @unique
  basePriceMonthly Int       @default(15000)
  extraClientPrice Int       @default(3500)
  includedClients  Int       @default(5)
  billingStatus    String    @default("ACTIVE")
  currentPeriodEnd DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  coach User @relation("CoachBilling", fields: [coachId], references: [id])
}

// ─── Message ─────────────────────────────────────────────────────────

model Message {
  id         Int      @id @default(autoincrement())
  senderId   String
  receiverId String
  content    String
  imageData  String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, isRead])
}

// ─── Social Feed ─────────────────────────────────────────────────────

model Post {
  id        Int       @id @default(autoincrement())
  authorId  String
  coachId   String?
  content   String
  mediaType String?
  mediaUrl  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  coach     User?       @relation("CoachPosts", fields: [coachId], references: [id])
  likes     PostLike[]
  comments  PostComment[]

  @@index([coachId, createdAt])
}

model PostLike {
  id     Int    @id @default(autoincrement())
  postId Int
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostComment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    String
  content   String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// ─── Recipe & Related ────────────────────────────────────────────────

model RecipeCategory {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String
  coachId      String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  coach   User?    @relation("CoachRecipeCategories", fields: [coachId], references: [id])
  recipes Recipe[]

  @@unique([slug, coachId])
  @@index([coachId])
}

model DietaryTag {
  id      Int                @id @default(autoincrement())
  name    String
  slug    String
  coachId String?

  coach   User?              @relation("CoachDietaryTags", fields: [coachId], references: [id])
  recipes RecipeDietaryTag[]

  @@unique([slug, coachId])
  @@index([coachId])
}

model Recipe {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String
  coachId      String?
  description  String
  categoryId   Int
  ingredients  String
  instructions String
  videoUrl     String?
  imageUrl     String?
  calories     Int
  protein      Float
  carbs        Float
  fat          Float
  servings     Int      @default(1)
  prepTimeMins Int      @default(0)
  cookTimeMins Int      @default(0)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  coach        User?              @relation("CoachRecipes", fields: [coachId], references: [id])
  category     RecipeCategory     @relation(fields: [categoryId], references: [id])
  dietaryTags  RecipeDietaryTag[]
  favourites   Favourite[]
  planDayMeals PlanDayMeal[]

  @@unique([slug, coachId])
  @@index([coachId])
  @@index([categoryId, isPublished])
}

model RecipeDietaryTag {
  recipeId Int
  tagId    Int
  recipe   Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag      DietaryTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([recipeId, tagId])
}

// ─── Favourites ──────────────────────────────────────────────────────

model Favourite {
  id        Int      @id @default(autoincrement())
  userId    String
  recipeId  Int?
  workoutId Int?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe?  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  workout   Workout? @relation(fields: [workoutId], references: [id])
}

// ─── Workout Videos ──────────────────────────────────────────────────

model WorkoutCategory {
  id            Int                  @id @default(autoincrement())
  name          String
  slug          String
  coachId       String?
  displayOrder  Int                  @default(0)

  coach         User?                @relation("CoachWorkoutCats", fields: [coachId], references: [id])
  subcategories WorkoutSubcategory[]

  @@unique([slug, coachId])
  @@index([coachId])
}

model WorkoutSubcategory {
  id         Int             @id @default(autoincrement())
  name       String
  slug       String
  coachId    String?
  categoryId Int

  coach    User?           @relation("CoachWorkoutSubs", fields: [coachId], references: [id])
  category WorkoutCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  workouts Workout[]

  @@unique([slug, coachId])
  @@index([coachId])
}

model Workout {
  id            Int                @id @default(autoincrement())
  title         String
  slug          String
  coachId       String?
  description   String
  videoUrl      String
  instructions  String
  subcategoryId Int
  difficulty    String             @default("Intermediate")
  duration      String?
  sets          String?
  reps          String?
  targetGoal    String?
  isPublished   Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  coach            User?              @relation("CoachWorkouts", fields: [coachId], references: [id])
  subcategory      WorkoutSubcategory @relation(fields: [subcategoryId], references: [id])
  planTemplateDays PlanTemplateDay[]
  clientPlanDays   ClientPlanDay[]
  favourites       Favourite[]

  @@unique([slug, coachId])
  @@index([coachId])
  @@index([subcategoryId, isPublished])
}

// ─── Food Database ───────────────────────────────────────────────────

model FoodItem {
  id              Int      @id @default(autoincrement())
  name            String
  coachId         String?
  category        String
  subcategory     String?
  caloriesPer100g Int
  proteinPer100g  Float
  carbsPer100g    Float
  fatPer100g      Float
  fiberPer100g    Float?
  servingSize     Int?
  servingUnit     String?
  isVerified      Boolean  @default(true)
  createdAt       DateTime @default(now())

  coach User? @relation("CoachFoodItems", fields: [coachId], references: [id])

  @@index([coachId])
  @@index([category])
  @@index([name])
}

// ─── Step Tracker ────────────────────────────────────────────────────

model StepLog {
  id         Int      @id @default(autoincrement())
  userId     String
  steps      Int
  goal       Int      @default(10000)
  loggedDate DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, loggedDate])
  @@index([userId, loggedDate])
}

// ─── Body Measurements ───────────────────────────────────────────────

model BodyMeasurement {
  id          Int      @id @default(autoincrement())
  userId      String
  loggedDate  DateTime
  weightKg    Float?
  bellyInches Float?
  chestInches Float?
  waistInches Float?
  hipsInches  Float?
  armsInches  Float?
  imageData   String?
  notes       String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, loggedDate])
  @@index([userId, loggedDate])
}

// ─── Notifications ───────────────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  userId    String
  title     String
  message   String
  type      String   @default("system")
  actionUrl String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model UserReminder {
  id      Int     @id @default(autoincrement())
  userId  String
  type    String
  time    String
  enabled Boolean @default(true)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

// ─── User Tracking ───────────────────────────────────────────────────

model WeightLog {
  id         Int      @id @default(autoincrement())
  userId     String
  weightKg   Float
  loggedDate DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, loggedDate])
  @@index([userId, loggedDate])
}

model ProgressPhoto {
  id        Int      @id @default(autoincrement())
  userId    String
  imageData String
  photoDate DateTime
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model MealLog {
  id          Int      @id @default(autoincrement())
  userId      String
  description String
  mealType    String   @default("Snack")
  calories    Int
  protein     Float
  carbs       Float
  fat         Float
  imageData   String?
  ingredients String?
  loggedDate  DateTime
  loggedTime  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, loggedDate])
}

// ─── Site Content ────────────────────────────────────────────────────

model SiteContent {
  id           Int      @id @default(autoincrement())
  contentKey   String
  coachId      String?
  contentValue String
  contentType  String   @default("TEXT")
  updatedAt    DateTime @updatedAt

  coach User? @relation("CoachSiteContent", fields: [coachId], references: [id])

  @@unique([contentKey, coachId])
}

// ─── Asset ───────────────────────────────────────────────────────────

model Asset {
  id           Int      @id @default(autoincrement())
  filename     String
  data         String
  fileSize     Int
  mimeType     String
  altText      String?
  coachId      String?
  uploadedById String?
  createdAt    DateTime @default(now())

  coach      User? @relation("CoachAssets", fields: [coachId], references: [id])
  uploadedBy User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([coachId])
}

// ─── User Macro Target ──────────────────────────────────────────────

model UserMacroTarget {
  id        Int      @id @default(autoincrement())
  userId    String   @unique
  calories  Int
  protein   Int
  carbs     Int
  fat       Int
  goal      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Payment Settings ───────────────────────────────────────────────

model PaymentSettings {
  id            Int     @id @default(autoincrement())
  coachId       String? @unique
  accountNumber String
  accountName   String
  qrCodeData    String?
  instructions  String?
  price         Int     @default(79)
  currency      String  @default("PKR")

  coach User? @relation("CoachPaymentSettings", fields: [coachId], references: [id])
}

// ─── Plan Templates ──────────────────────────────────────────────────

model PlanTemplate {
  id            Int      @id @default(autoincrement())
  name          String
  coachId       String?
  description   String?
  type          String   @default("combined")
  durationWeeks Int      @default(4)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  coach       User?             @relation("CoachPlanTemplates", fields: [coachId], references: [id])
  days        PlanTemplateDay[]
  clientPlans ClientPlan[]

  @@index([coachId])
}

model PlanTemplateDay {
  id            Int     @id @default(autoincrement())
  templateId    Int
  dayOfWeek     Int
  weekNumber    Int     @default(1)
  workoutId     Int?
  workoutNotes  String?
  mealPlan      String?
  calorieTarget Int?
  proteinTarget Float?
  carbsTarget   Float?
  fatTarget     Float?
  notes         String?

  template PlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  workout  Workout?     @relation(fields: [workoutId], references: [id])
  meals    PlanDayMeal[]

  @@index([templateId, weekNumber, dayOfWeek])
}

// ─── Client Plans (assigned to users) ────────────────────────────────

model ClientPlan {
  id          Int       @id @default(autoincrement())
  userId      String
  templateId  Int?
  name        String
  description String?
  type        String    @default("combined")
  startDate   DateTime
  endDate     DateTime?
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  template PlanTemplate? @relation(fields: [templateId], references: [id])
  days     ClientPlanDay[]
  progress DailyProgress[]

  @@index([userId, status])
}

model ClientPlanDay {
  id            Int     @id @default(autoincrement())
  clientPlanId  Int
  dayOfWeek     Int
  weekNumber    Int     @default(1)
  workoutId     Int?
  workoutNotes  String?
  mealPlan      String?
  calorieTarget Int?
  proteinTarget Float?
  carbsTarget   Float?
  fatTarget     Float?
  notes         String?

  clientPlan ClientPlan @relation(fields: [clientPlanId], references: [id], onDelete: Cascade)
  workout    Workout?   @relation(fields: [workoutId], references: [id])
  meals      PlanDayMeal[]

  @@index([clientPlanId, weekNumber, dayOfWeek])
}

// ─── Plan Day Meals (recipe links per meal type) ────────────────────

model PlanDayMeal {
  id            Int    @id @default(autoincrement())
  templateDayId Int?
  clientDayId   Int?
  mealType      String
  recipeId      Int
  servings      Float  @default(1)
  sortOrder     Int    @default(0)

  templateDay PlanTemplateDay? @relation(fields: [templateDayId], references: [id], onDelete: Cascade)
  clientDay   ClientPlanDay?   @relation(fields: [clientDayId], references: [id], onDelete: Cascade)
  recipe      Recipe           @relation(fields: [recipeId], references: [id])

  @@index([templateDayId, mealType])
  @@index([clientDayId, mealType])
  @@index([recipeId])
}

// ─── Daily Progress ──────────────────────────────────────────────────

model DailyProgress {
  id               Int      @id @default(autoincrement())
  userId           String
  clientPlanId     Int
  date             DateTime
  workoutCompleted     Boolean  @default(false)
  breakfastCompleted   Boolean  @default(false)
  lunchCompleted       Boolean  @default(false)
  snackCompleted       Boolean  @default(false)
  dinnerCompleted      Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientPlan ClientPlan @relation(fields: [clientPlanId], references: [id], onDelete: Cascade)

  @@unique([userId, clientPlanId, date])
  @@index([userId, date])
}

// ─── Weekly Targets ──────────────────────────────────────────────────

model WeeklyTarget {
  id            Int      @id @default(autoincrement())
  userId        String
  weekStartDate DateTime
  metric        String
  targetValue   Float
  currentValue  Float?
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekStartDate])
}

// ─── Login Attempts (rate limiting) ──────────────────────────────────

model LoginAttempt {
  id          Int      @id @default(autoincrement())
  email       String
  ipAddress   String?
  success     Boolean
  attemptedAt DateTime @default(now())

  @@index([email, attemptedAt])
  @@index([ipAddress, attemptedAt])
}
